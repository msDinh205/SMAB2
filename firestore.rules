rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public access since Firebase Auth is removed per user request
    // WARNING: This is insecure and should only be used for prototypes
    
    match /appData/{docId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
